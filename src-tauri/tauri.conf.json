{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NAICS Snap",
  "version": "1.0.0",
  "identifier": "com.ryan.naicssnap",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NAICS Snap",
        "width": 1040,
        "height": 720,
        "minWidth": 720,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/naics_2022.sqlite"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": { "type": "offlineInstaller" },
      "allowDowngrades": true
    }
  }
}
